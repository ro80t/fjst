{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "adapter-cf-workers",
  "compatibility_date": "2026-04-06",
  "compatibility_flags": ["nodejs_als"],
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare",
  },
  "workers_dev": true,
  "preview_urls": true,
}
